# Razorpay Configuration
# Get these from https://dashboard.razorpay.com/settings/api-keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# Server Configuration
PORT=5000
HOST=localhost
NODE_ENV=development

# Email Configuration (for prescription delivery)
# Using Gmail SMTP or other provider
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SUPPORT_EMAIL=support@carewithoutborders.com

# Alternative: Using SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# Frontend Configuration
REACT_APP_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
REACT_APP_API_BASE_URL=http://localhost:5000

# Firebase Configuration (if using Firebase)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
